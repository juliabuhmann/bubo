Bootstrap: docker
From: ghcr.io/astral-sh/uv:latest
Stage: uv_stage

Bootstrap: docker
From: ubuntu:24.04

%files from uv_stage
    /uv /bin/
    /uvx /bin/

%files
    /cluster/home/buhmanju/src/bubo/codex/environment.yml /opt/environment.yml

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get install -y --no-install-recommends \
        bubblewrap \
        build-essential \
        ca-certificates \
        curl \
        git \
        python-is-python3 \
        python3-dev \
        python3-pip \
        time \
        wget \
        zstd

    # Node.js 24
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash -
    apt-get update && apt-get install -y --no-install-recommends nodejs
    rm -rf /var/lib/apt/lists/* && apt-get clean

    # Install codex CLI (same as euler-vibe)
    npm install -g @openai/codex@latest
    npm cache clean --force

    # Install miniforge (provides conda + mamba)
    curl -fsSLo /tmp/miniforge.sh \
        https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm /tmp/miniforge.sh
    export PATH="/opt/conda/bin:$PATH"

    # Install pandas for system Python — needed by run_benchmark.py itself
    export UV_LINK_MODE=copy
    uv pip install --system pandas openpyxl

    # Create the compbio-benchmark conda env from environment.yml (~10-15 min)
    /opt/conda/bin/mamba env create -f /opt/environment.yml

    # Clean up conda package caches to reduce image size
    /opt/conda/bin/conda clean -afy

%environment
    export PATH="/opt/conda/bin:$PATH"

%runscript
    export PATH="/opt/conda/bin:$PATH"
    exec "$@"
